# ============================================================================
# Configuration de l'API Ozerus — modèle (valeurs réelles hors du dépôt)
# Copier en `.env` et renseigner. Ne jamais committer de secrets en clair.
# ============================================================================

# Port HTTP de l'API
PORT=4000

# Origines autorisées (CORS), séparées par des virgules
FRONT_ORIGIN=http://localhost:3000,http://localhost:3001

# --- Base de données (PostgreSQL / Prisma) -----------------------------------
DATABASE_URL=postgresql://ozerus:ozerus@localhost:5432/ozerus?schema=public

# --- Authentification (identity) ---------------------------------------------
# Secret de signature des JWT — générer avec : openssl rand -hex 32
JWT_SECRET=
# Durées de vie des tokens (optionnel)
JWT_ACCESS_EXPIRATION=4h
JWT_REFRESH_EXPIRATION=7d
JWT_MFA_PENDING_EXPIRATION_SECONDS=300
# Clé de chiffrement des secrets MFA (optionnel ; à défaut JWT_SECRET est utilisé)
MFA_ENC_KEY=
# Domaine imposé pour les invitations (optionnel)
INVITE_EMAIL_DOMAIN=

# Compte administrateur initial (seed au démarrage)
ADMIN_EMAIL=admin@example.invalid
ADMIN_PASSWORD=

# --- Emails (communication / core mail) --------------------------------------
# Sans SMTP_URL, les envois sont seulement journalisés (no-op sûr en dev)
SMTP_URL=smtp://localhost:1025
MAIL_FROM=Ozerus <no-reply@exemple.invalid>
COMMUNICATION_APP_NAME=Ozerus
COMMUNICATION_SUPPORT_EMAIL=support@exemple.invalid
COMMUNICATION_FALLBACK_LOCALE=fr
